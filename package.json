{
  "name": "git-analytics",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "types:check": "tsc --noEmit -p tsconfig.app.json",
    "lint:check": "eslint . --max-warnings 0",
    "lint:fix": "eslint --fix .",
    "prettier:check": "npx prettier . --check",
    "prettier:fix": "npx prettier --write .",
    "prepare": "husky",
    "build:check": "npm run prettier:check && npm run lint:check && npm run types:check && npm run test && npm run build",
    "format:fix": "npm run prettier:fix && npm run lint:fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "branch:protection": "sh ./bin/branch-protection.sh",
    "generate:widget": "node ./scripts/generate-widget.js",
    "generate:feature": "node ./scripts/generate-feature.js",
    "generate:page": "node ./scripts/generate-page.js"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@octokit/openapi-types": "^27.0.0",
    "@octokit/rest": "^22.0.1",
    "@octokit/types": "^16.0.0",
    "@tanstack/react-query": "^5.95.0",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-virtual": "^3.13.23",
    "antd": "^6.3.1",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.6",
    "react-infinite-scroll-hook": "^5.0.2",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.3.11",
    "use-debounce": "^10.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^9.39.1",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.14",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "npx eslint --fix",
      "npx vitest related --run"
    ],
    "**/*": [
      "npx prettier . --check"
    ]
  }
}
